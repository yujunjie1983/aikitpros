{
  "version": 2,
  "buildCommand": "npm run build && cp public/landing.html dist/landing.html && cp public/demo.html dist/demo.html",
  "installCommand": "yarn",
  "redirects": [
    { "source": "/", "destination": "/landing.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/((?!landing.html|demo.html|assets|favicon.ico|robots.txt|sitemap.xml|llms.txt).*)", "destination": "/index.html" }
  ]
}
